datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Invoice {
  id          Int      @id @default(autoincrement())
  customerId  String
  amount      Float
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
}